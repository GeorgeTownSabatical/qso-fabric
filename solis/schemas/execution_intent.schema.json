{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "execution_intent.schema.json",
  "title": "Solis Execution Intent",
  "type": "object",
  "required": [
    "schema_version",
    "intent_id",
    "strategy_id",
    "as_of_ts",
    "symbol_set",
    "requested_exposure_delta_bps",
    "horizon_ms",
    "confidence",
    "model_version",
    "features_commit_hash"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "intent_id": {
      "type": "string",
      "minLength": 1
    },
    "strategy_id": {
      "type": "string",
      "minLength": 1
    },
    "as_of_ts": {
      "type": "string",
      "format": "date-time"
    },
    "symbol_set": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._:/-]+$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "requested_exposure_delta_bps": {
      "type": "integer",
      "minimum": -10000,
      "maximum": 10000
    },
    "horizon_ms": {
      "type": "integer",
      "minimum": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "model_version": {
      "type": "string",
      "minLength": 1
    },
    "features_commit_hash": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{40,64}$"
    },
    "compiler_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "policy_version": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "risk_hints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    }
  },
  "additionalProperties": false
}
