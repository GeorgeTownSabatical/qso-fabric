{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "governor_decision.schema.json",
  "title": "Solis Governor Decision",
  "type": "object",
  "required": [
    "schema_version",
    "decision_id",
    "decision_ts",
    "intent_id",
    "decision",
    "reason_codes",
    "invariant_trace",
    "policy_version",
    "actor",
    "signature"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "decision_id": {
      "type": "string",
      "minLength": 1
    },
    "decision_ts": {
      "type": "string",
      "format": "date-time"
    },
    "intent_id": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "enum": [
        "REJECTED",
        "APPROVED_SHADOW",
        "APPROVED_EXECUTE"
      ]
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "invariant_trace": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "status",
          "detail"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "PASS",
              "FAIL",
              "SKIP"
            ]
          },
          "detail": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "policy_version": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "signature": {
      "type": "string",
      "minLength": 1
    },
    "decision_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "additionalProperties": false
}
